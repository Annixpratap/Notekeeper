{
  "name": "notes-app-backend",
  "version": "1.0.0",
  "description": "Notes App Backend - Express.js with Prisma ORM",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node prisma/seed.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src --ext .js"
  },
  "keywords": [
    "notes",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.7.1",
    "axios": "1.6.2",
    "bcrypt": "5.1.1",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "jsonwebtoken": "9.0.3",
    "swagger-ui-express": "5.0.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.10.6",
    "prisma": "5.7.1",
    "vitest": "1.1.0"
  }
}
